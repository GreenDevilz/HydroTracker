<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="?attr/cardBackground"
    android:padding="@dimen/padding_large"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/blue_600"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/margin_large"
        android:text="@string/reminder_settings_title"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/margin_medium">
        <TextView
            android:textSize="16sp"
            android:textColor="?attr/textPrimary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/label_enable_reminders"
            android:layout_weight="1"/>
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchReminders"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    <TextView
        android:textSize="14sp"
        android:textColor="?attr/textSecondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_medium"
        android:layout_marginBottom="@dimen/margin_small"
        android:text="@string/label_remind_every"/>
    <Spinner
        android:id="@+id/spinnerInterval"
        android:background="@drawable/spinner_background"
        android:padding="@dimen/padding_small"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="@dimen/margin_medium"/>
    <TextView
        android:textSize="14sp"
        android:textColor="?attr/textSecondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/margin_small"
        android:text="@string/label_between"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textColor="?attr/textPrimary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_from"
            android:layout_marginEnd="@dimen/margin_small"/>
        <NumberPicker
            android:id="@+id/pickerStartHour"
            android:descendantFocusability="blocksDescendants"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"/>
        <TextView
            android:textColor="?attr/textPrimary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_hour_suffix"
            android:layout_marginHorizontal="@dimen/margin_small"/>
        <TextView
            android:textColor="?attr/textPrimary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_to"
            android:layout_marginEnd="@dimen/margin_small"/>
        <NumberPicker
            android:id="@+id/pickerEndHour"
            android:descendantFocusability="blocksDescendants"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"/>
        <TextView
            android:textColor="?attr/textPrimary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_hour_suffix"
            android:layout_marginStart="@dimen/margin_small"/>
    </LinearLayout>
    <!-- Custom Reminder Message -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/reminder_custom_title"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="?attr/textPrimary"
        android:layout_marginTop="@dimen/margin_medium"
        android:layout_marginBottom="@dimen/margin_small"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/cardBackground"
        android:padding="@dimen/padding_medium"
        android:layout_marginBottom="@dimen/margin_medium">

        <CheckBox
            android:id="@+id/checkUseCustomMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reminder_use_custom"
            android:textColor="?attr/textPrimary"
            android:padding="@dimen/padding_small"
            android:layout_marginBottom="@dimen/margin_small"/>

        <EditText
            android:id="@+id/inputCustomMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/reminder_custom_hint"
            android:padding="@dimen/padding_medium"
            android:background="@drawable/edit_text_background"
            android:textSize="14sp"
            android:textColor="?attr/textPrimary"
            android:textColorHint="?attr/textSecondary"
            android:enabled="false"
            android:inputType="textCapSentences|textMultiLine"
            android:autofillHints="none"
            android:minLines="2"
            android:maxLines="3"
            android:layout_marginBottom="@dimen/margin_small"/>

        <TextView
            android:id="@+id/txtMessagePreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reminder_default"
            android:textSize="13sp"
            android:textColor="?attr/textPrimary"
            android:padding="@dimen/padding_small"
            android:background="@color/blue_50"
            android:alpha="0.9"/>
    </LinearLayout>
</LinearLayout>
