<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:background="?android:attr/colorBackground"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">
    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp">
            <TextView
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/blue_600"
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:text="@string/app_display_name"
                android:layout_centerVertical="true"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_toStartOf="@+id/btnProfile"
                android:layout_alignParentStart="true"/>

            <ImageView
                android:id="@+id/btnProfile"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:layout_centerVertical="true"
                android:layout_toStartOf="@+id/btnReminder"
                android:layout_marginEnd="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="12dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_user_profile"
                android:contentDescription="@string/user_profile"
                app:tint="@color/blue_600" />

            <ImageView
                android:id="@+id/btnReminder"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="12dp"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:src="@drawable/ic_bell"
                android:layout_centerVertical="true"
                android:contentDescription="@string/reminder_button"
                android:layout_alignParentEnd="true"
                app:tint="@color/blue_600"/>
        </RelativeLayout>
        <FrameLayout
            android:id="@+id/progressBarContainer"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="20dp">
            <View
                android:layout_gravity="center"
                android:background="?attr/progressBackground"
                android:layout_width="match_parent"
                android:layout_height="20dp"/>
            <View
                android:layout_gravity="start"
                android:id="@+id/horizontalProgress"
                android:background="@drawable/progress_gradient"
                android:layout_width="0dp"
                android:layout_height="20dp"/>
        </FrameLayout>
        <com.example.waterintaketracker.WaterBottleView
            android:id="@+id/bottleVisual"
            android:layout_width="match_parent"
            android:layout_height="460dp"
            android:layout_marginVertical="10dp"/>
        <TextView
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/txtEncouragement"
            android:background="@drawable/message_bubble"
            android:padding="8dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:elevation="4dp"
            android:layout_marginVertical="10dp"/>
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="10dp"
            app:cardBackgroundColor="?attr/cardBackground"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:orientation="horizontal"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <TextView
                        android:textSize="12sp"
                        android:textColor="?attr/textSecondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_current"/>
                    <TextView
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="?attr/textPrimary"
                        android:id="@+id/currentIntake"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_intake"/>
                </LinearLayout>
                <View
                    android:background="?attr/progressBackground"
                    android:layout_width="1dp"
                    android:layout_height="40dp"/>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <TextView
                        android:textSize="12sp"
                        android:textColor="?attr/textSecondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_goal"/>
                    <TextView
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="?attr/textPrimary"
                        android:id="@+id/dailyGoal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_goal"/>
                </LinearLayout>
                <View
                    android:background="?attr/progressBackground"
                    android:layout_width="1dp"
                    android:layout_height="40dp"/>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <TextView
                        android:textSize="12sp"
                        android:textColor="?attr/textSecondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_progress"/>
                    <TextView
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#0284c7"
                        android:id="@+id/percentageText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_percentage"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <TextView
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#334155"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="8dp"
            android:text="@string/label_quick_add"/>
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">
            <Button
                android:id="@+id/btnAddSmall"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/btn_add_small"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                style="@style/Widget.Material3.Button.TonalButton"/>
            <Button
                android:id="@+id/btnAddMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/btn_add_medium"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                style="@style/Widget.Material3.Button.TonalButton"/>
            <Button
                android:id="@+id/btnAddLarge"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/btn_add_large"
                android:layout_weight="1"
                style="@style/Widget.Material3.Button.TonalButton"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp">
            <Button
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/blue_700"
                android:gravity="center"
                android:id="@+id/btnUndo"
                android:background="?attr/selectableItemBackground"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:text="@string/btn_undo"
                android:layout_weight="1"
                style="@style/Widget.Material3.Button.TextButton"/>
            <View
                android:background="@color/slate_300"
                android:layout_width="1dp"
                android:layout_height="24dp"/>
            <Button
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/blue_700"
                android:gravity="center"
                android:id="@+id/btnSettings"
                android:background="?attr/selectableItemBackground"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:text="@string/btn_settings"
                android:layout_weight="1"
                style="@style/Widget.Material3.Button.TextButton"/>
            <View
                android:background="@color/slate_300"
                android:layout_width="1dp"
                android:layout_height="24dp"/>
            <Button
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/blue_700"
                android:gravity="center"
                android:id="@+id/btnHistory"
                android:background="?attr/selectableItemBackground"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:text="@string/btn_history"
                android:layout_weight="1"
                style="@style/Widget.Material3.Button.TextButton"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/factContainer"
            android:background="?attr/cardBackground"
            android:padding="12dp"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp"
            android:elevation="2dp">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">
                <TextView
                    android:textSize="20sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/fact_bulb_emoji"/>
                <TextView
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/blue_600"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/did_you_know"/>
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="11sp"
                    android:textColor="?attr/textSecondary"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/tvFactCounter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:alpha="0.6"/>
            </LinearLayout>
            <TextView
                android:textSize="14sp"
                android:textColor="?attr/textPrimary"
                android:id="@+id/tvDailyFact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/fact_1"
                android:lineSpacingExtra="2dp"
                android:paddingVertical="4dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
