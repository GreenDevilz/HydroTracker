<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/history_root"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground"
    android:padding="@dimen/padding_standard"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginBottom="@dimen/margin_large">
        <ImageButton
            android:id="@+id/btnBack"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="12dp"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:src="@drawable/ic_arrow_back"
            android:layout_centerVertical="true"
            android:contentDescription="@string/back_button"
            android:layout_alignParentStart="true"
            app:tint="?attr/textPrimary"/>
        <TextView
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/blue_600"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:text="@string/history_header"
            android:layout_centerVertical="true"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:layout_toStartOf="@+id/btnClearHistory"
            android:layout_toEndOf="@+id/btnBack"/>
        <ImageButton
            android:id="@+id/btnClearHistory"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="12dp"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:src="@drawable/ic_delete"
            android:layout_centerVertical="true"
            android:contentDescription="@string/clear_history"
            android:layout_alignParentEnd="true"
            app:tint="@color/red_600"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/margin_large">
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/margin_small"
            app:cardBackgroundColor="?attr/cardBackground"
            app:cardCornerRadius="12dp"
            app:cardElevation="@dimen/elevation_medium">
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <TextView
                    android:textSize="@dimen/text_size_result"
                    android:textStyle="bold"
                    android:textColor="@color/blue_600"
                    android:id="@+id/txtStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/default_streak"/>
                <TextView
                    android:textColor="?attr/textSecondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_streak"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/margin_small"
            app:cardBackgroundColor="?attr/cardBackground"
            app:cardCornerRadius="12dp"
            app:cardElevation="@dimen/elevation_medium">
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <TextView
                    android:textSize="@dimen/text_size_h1"
                    android:textStyle="bold"
                    android:textColor="@color/blue_600"
                    android:id="@+id/txtAverage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/default_intake"/>
                <TextView
                    android:textColor="?attr/textSecondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_average"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
    <TextView
        android:textSize="@dimen/text_size_h2"
        android:textStyle="bold"
        android:textColor="?attr/textPrimary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/margin_medium"
        android:text="@string/label_last_7_days"/>
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_marginBottom="@dimen/margin_large"
        android:importantForAccessibility="no">
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/chartContainer"
            android:padding="@dimen/padding_small"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"/>
    </HorizontalScrollView>
    <TextView
        android:textSize="@dimen/text_size_h2"
        android:textStyle="bold"
        android:textColor="?attr/textPrimary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/margin_medium"
        android:text="@string/label_recent_days"/>
    <ListView
        android:id="@+id/historyListView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:divider="@android:color/transparent"
        android:dividerHeight="@dimen/margin_small"
        android:layout_weight="1"/>
</LinearLayout>
