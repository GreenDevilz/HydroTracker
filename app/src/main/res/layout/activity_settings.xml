<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="?android:attr/colorBackground"
    android:id="@+id/scrollView"
    android:padding="@dimen/padding_standard"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="@dimen/margin_small"
            android:layout_marginBottom="@dimen/margin_large">
            <TextView
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/blue_600"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:text="@string/settings_header"
                android:layout_centerVertical="true"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"/>
        </RelativeLayout>
        <TextView
            android:textSize="@dimen/text_size_h2"
            android:textStyle="bold"
            android:textColor="?attr/textPrimary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/margin_medium"
            android:text="@string/section_personal"/>
        <LinearLayout
            android:orientation="vertical"
            android:background="?attr/cardBackground"
            android:padding="@dimen/padding_standard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/margin_large"
            android:elevation="@dimen/elevation_medium">
            <TextView
                android:textSize="@dimen/text_size_body"
                android:textColor="?attr/textPrimary"
                android:id="@+id/lblWeight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_small"
                android:text="@string/label_weight"
                android:labelFor="@+id/inputWeight"/>
            <EditText
                android:textColor="?attr/textPrimary"
                android:textColorHint="?attr/textSecondary"
                android:id="@+id/inputWeight"
                android:background="@drawable/edit_text_background"
                android:padding="@dimen/padding_medium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_standard"
                android:inputType="numberDecimal"
                android:importantForAccessibility="yes"
                android:autofillHints="none"/>
            <TextView
                android:textSize="@dimen/text_size_body"
                android:textColor="?attr/textPrimary"
                android:id="@+id/lblAge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_small"
                android:text="@string/label_age"
                android:labelFor="@+id/inputAge"/>
            <EditText
                android:textColor="?attr/textPrimary"
                android:textColorHint="?attr/textSecondary"
                android:id="@+id/inputAge"
                android:background="@drawable/edit_text_background"
                android:padding="@dimen/padding_medium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_standard"
                android:inputType="number"
                android:importantForAccessibility="yes"
                android:autofillHints="none"/>
            <TextView
                android:textSize="@dimen/text_size_body"
                android:textColor="?attr/textPrimary"
                android:id="@+id/lblGender"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_small"
                android:text="@string/label_gender"
                android:labelFor="@+id/radioGroupGender"/>
            <RadioGroup
                android:orientation="horizontal"
                android:id="@+id/radioGroupGender"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_standard">
                <RadioButton
                    android:textColor="?attr/textPrimary"
                    android:id="@+id/radioMale"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/gender_male"
                    android:layout_weight="1"/>
                <RadioButton
                    android:textColor="?attr/textPrimary"
                    android:id="@+id/radioFemale"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/gender_female"
                    android:layout_weight="1"/>
            </RadioGroup>
        </LinearLayout>
        <TextView
            android:textSize="@dimen/text_size_h2"
            android:textStyle="bold"
            android:textColor="?attr/textPrimary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/margin_medium"
            android:text="@string/section_lifestyle"/>
        <LinearLayout
            android:orientation="vertical"
            android:background="?attr/cardBackground"
            android:padding="@dimen/padding_standard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/margin_large"
            android:elevation="@dimen/elevation_medium">
            <TextView
                android:textSize="@dimen/text_size_body"
                android:textColor="?attr/textPrimary"
                android:id="@+id/lblActivity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_small"
                android:text="@string/label_activity_level"
                android:labelFor="@+id/spinnerActivity"/>
            <Spinner
                android:id="@+id/spinnerActivity"
                android:background="@drawable/spinner_background"
                android:padding="@dimen/padding_small"
                android:layout_width="match_parent"
                android:layout_height="@dimen/spinner_height"
                android:layout_marginBottom="@dimen/margin_standard"
                android:contentDescription="@string/label_activity_level"/>
            <TextView
                android:textSize="@dimen/text_size_body"
                android:textColor="?attr/textPrimary"
                android:id="@+id/lblClimate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_small"
                android:text="@string/label_climate"
                android:labelFor="@+id/spinnerClimate"/>
            <Spinner
                android:id="@+id/spinnerClimate"
                android:background="@drawable/spinner_background"
                android:padding="@dimen/padding_small"
                android:layout_width="match_parent"
                android:layout_height="@dimen/spinner_height"
                android:layout_marginBottom="@dimen/margin_standard"
                android:contentDescription="@string/label_climate"/>
        </LinearLayout>
        <TextView
            android:textSize="@dimen/text_size_h2"
            android:textStyle="bold"
            android:textColor="?attr/textPrimary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/margin_medium"
            android:text="@string/section_special"/>
        <LinearLayout
            android:orientation="vertical"
            android:background="?attr/cardBackground"
            android:padding="@dimen/padding_standard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/margin_large"
            android:elevation="@dimen/elevation_medium">
            <CheckBox
                android:textColor="?attr/textPrimary"
                android:id="@+id/checkPregnancy"
                android:padding="@dimen/padding_small"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/condition_pregnancy"/>
            <CheckBox
                android:textColor="?attr/textPrimary"
                android:id="@+id/checkBreastfeeding"
                android:padding="@dimen/padding_small"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/condition_breastfeeding"/>
            <CheckBox
                android:textColor="?attr/textPrimary"
                android:id="@+id/checkFever"
                android:padding="@dimen/padding_small"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/condition_fever"/>
            <CheckBox
                android:textColor="?attr/textPrimary"
                android:id="@+id/checkExcessiveSweating"
                android:padding="@dimen/padding_small"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/condition_excessive_sweating"/>
            <CheckBox
                android:textColor="?attr/textPrimary"
                android:id="@+id/checkHighUrine"
                android:padding="@dimen/padding_small"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/condition_high_urine"/>
            <CheckBox
                android:textColor="?attr/textPrimary"
                android:id="@+id/checkHighProtein"
                android:padding="@dimen/padding_small"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/condition_high_protein"/>
            <CheckBox
                android:textColor="?attr/textPrimary"
                android:id="@+id/checkCreatine"
                android:padding="@dimen/padding_small"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/condition_creatine"/>
            <CheckBox
                android:textStyle="bold"
                android:textColor="@color/red_600"
                android:id="@+id/checkRestricted"
                android:padding="@dimen/padding_small"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:checked="false"
                android:text="@string/condition_heart_kidney"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/restrictedModeCard"
            android:background="@drawable/restricted_card_background"
            android:padding="@dimen/padding_standard"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/margin_large"
            android:elevation="@dimen/elevation_medium">
            <TextView
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/warningText"
                android:gravity="center"
                android:background="?attr/warningHeader"
                android:padding="@dimen/padding_medium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_medium"
                android:text="@string/restricted_mode_title"/>
            <TextView
                android:textSize="15sp"
                android:textColor="?attr/textPrimary"
                android:background="?attr/cardBackground"
                android:padding="@dimen/padding_medium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_medium"
                android:text="@string/restricted_mode_message"/>
            <TextView
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="?attr/textPrimary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_small"
                android:text="@string/restricted_mode_instruction"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/padding_small"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <EditText
                    android:textSize="16sp"
                    android:textColor="?attr/textPrimary"
                    android:textColorHint="?attr/textSecondary"
                    android:id="@+id/inputCustomGoal"
                    android:background="@drawable/edit_text_background"
                    android:padding="@dimen/padding_medium"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:hint="@string/custom_goal_hint"
                    android:layout_weight="1"
                    android:inputType="number"
                    android:layout_marginEnd="@dimen/margin_small"
                    android:autofillHints="none"/>
                <Button
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:id="@+id/btnSetCustomGoal"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="@string/btn_set_custom"
                    android:paddingStart="@dimen/padding_medium"
                    android:paddingEnd="@dimen/padding_medium"
                    android:backgroundTint="@color/red_600"
                    style="@style/Widget.AppCompat.Button.Colored"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/resultCard"
            android:background="?attr/cardBackground"
            android:padding="@dimen/padding_standard"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/margin_large"
            android:elevation="@dimen/elevation_medium">
            <TextView
                android:textSize="@dimen/text_size_body"
                android:textColor="?attr/textPrimary"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_small"
                android:text="@string/label_recommended_intake"/>
            <TextView
                android:textSize="@dimen/text_size_result"
                android:textStyle="bold"
                android:textColor="@color/blue_600"
                android:gravity="center"
                android:id="@+id/txtRecommendedGoal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_medium"
                android:text="@string/default_goal"/>
            <Button
                android:textColor="@color/white"
                android:id="@+id/btnApply"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_apply"
                android:backgroundTint="@color/blue_600"
                style="@style/Widget.Material3.Button"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/margin_large">
            <Button
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/btn_cancel"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/margin_small"
                style="@style/Widget.Material3.Button.OutlinedButton"/>
            <Button
                android:textColor="@color/white"
                android:id="@+id/btnCalculate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/btn_calculate"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/margin_small"
                android:backgroundTint="@color/blue_600"
                style="@style/Widget.Material3.Button"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
